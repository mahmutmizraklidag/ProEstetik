@model ProEstetik.Web.Entities.Service

@{
    ViewData["Title"] = "Düzenle";
}

<div class="container my-4">
    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-header bg-primary text-white d-flex align-items-center">
            <i class="bi bi-file-image me-2 fs-4"></i>
            <h4 class="mb-0">Hizmet Düzenle</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Title" class="form-label fw-bold"></label>
                        <input asp-for="Title" class="form-control" placeholder="Başlık Giriniz" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="HomeTitle" class="form-label fw-bold"></label>
                        <input asp-for="HomeTitle" class="form-control" placeholder="Anasayfa Başlığı Giriniz" />
                        <span asp-validation-for="HomeTitle" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ShortDescription" class="form-label fw-bold"></label>
                        <input asp-for="ShortDescription" class="form-control" placeholder="Kısa Açıklama Giriniz" />
                        <span asp-validation-for="ShortDescription" class="text-danger"></span>
                    </div>


                    <div class="col-md-6">
                        <label asp-for="Image" class="form-label fw-bold"></label>
                        <input asp-for="Image" class="form-control" type="file" />
                        <span asp-validation-for="Image" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Image2" class="form-label fw-bold"></label>
                        <input asp-for="Image2" class="form-control" type="file" />
                        <span asp-validation-for="Image2" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Slug" class="form-label fw-bold"></label>
                        <input asp-for="Slug" class="form-control" placeholder="Slug Giriniz" />
                        <span asp-validation-for="Slug" class="text-danger"></span>
                    </div>
                
                    <div class="col-md-6">
                        <label asp-for="Keywords" class="form-label fw-bold"></label>
                        <input asp-for="Keywords" class="form-control" placeholder="Meta-Keywords" />
                        <span asp-validation-for="Keywords" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="MetaDescription" class="form-label fw-bold"></label>
                        <input asp-for="MetaDescription" class="form-control" placeholder="Meta-Description" />
                        <span asp-validation-for="MetaDescription" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="MetaTitle" class="form-label fw-bold"></label>
                        <input asp-for="MetaTitle" class="form-control" placeholder="Meta-Title" />
                        <span asp-validation-for="MetaTitle" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Description" class="form-label fw-bold"></label>
                        <textarea id="AboutEditor" asp-for="Description" class="form-control"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Language" class="form-label fw-semibold"></label>
                        <select asp-for="Language" class="form-select"
                                asp-items="Html.GetEnumSelectList<Language>()">
                        </select>
                        <span asp-validation-for="Language" class="text-danger"></span>

                    </div>

                    <div class="col-12">
                        <input type="submit" value="Ekle" class="btn btn-primary btn-lg w-100 mt-3 shadow-sm" />
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
<style>
    .card-header {
        display: flex;
        align-items: center;
        font-size: 1.2rem;
    }

    input.form-control, textarea.form-control {
        border-radius: 8px;
        box-shadow: none;
    }

        input.form-control:focus, textarea.form-control:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 8px rgba(13, 110, 253, 0.2);
        }

</style>
@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const editor = new Jodit('#AboutEditor', {
                height: 400
            });
        });
    </script>
}
