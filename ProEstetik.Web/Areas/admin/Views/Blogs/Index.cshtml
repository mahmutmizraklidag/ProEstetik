@model IEnumerable<Blog>

@{
    ViewData["Title"] = "Blog";
}



<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold text-primary mb-0">
            <i class="bi bi-file-image me-1"></i> Blog
        </h2>
        <a class="btn btn-outline-success shadow-sm" asp-action="Create">
            <i class="bi bi-plus-circle"></i> Blog Ekle
        </a>
    </div>

    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-body p-3">
            <div class="table-responsive">
                <table id="myTable" class="display table table-hover table-striped align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.Title)</th>
                            <th>@Html.DisplayNameFor(model => model.Description)</th>
                            <th>@Html.DisplayNameFor(model => model.Image)</th>
                         
                            <th>@Html.DisplayNameFor(model => model.Slug)</th>
                            <th>@Html.DisplayNameFor(model => model.CreatedAt)</th>
                            <th>@Html.DisplayNameFor(model => model.Keywords)</th>
                            <th>@Html.DisplayNameFor(model => model.MetaDescription)</th>
                            <th>@Html.DisplayNameFor(model => model.MetaTitle)</th>
                            <th>@Html.DisplayNameFor(model => model.Language)</th>
                            <th class="text-center">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>

                                <td>@Html.DisplayFor(modelItem => item.Title)</td>
                                <td class="about-column">açıklama</td>
                                <td>
                                    <img src="/image/@item.Image" alt="slider" class="rounded shadow-sm border" height="60" />
                                </td>
                              
                               
                               
                                <td>@Html.DisplayFor(modelItem => item.Slug)</td>
                                <td>@Html.DisplayFor(modelItem => item.CreatedAt)</td>
                                <td>@Html.DisplayFor(modelItem => item.Keywords)</td>
                                <td>@Html.DisplayFor(modelItem => item.MetaDescription)</td>
                                <td>@Html.DisplayFor(modelItem => item.MetaTitle)</td>
                                <td class="about-column">@Html.Raw(item.Language)</td>
                                <td class="text-center">
                                    <div class="btn-group-vertical btn-group-sm" role="group">
                                        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@item.Id">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a class="btn btn-danger" asp-action="Delete" asp-route-id="@item.Id">
                                            <i class="bi bi-trash"></i>
                                        </a>

                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
<style>
    .table img {
        transition: transform 0.2s ease;
    }

        .table img:hover {
            transform: scale(1.1);
        }

    .btn-group-vertical .btn {
        margin: 2px 0;
    }

</style>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#myTable').DataTable({
                // Türkçe dil desteği
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/tr.json"
                }
            });
        });
    </script>
}