@model ProEstetik.Web.Entities.SiteSetting

@{
    ViewData["Title"] = "Düzenle";
}


<div class="container my-4">
    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-header bg-primary text-white d-flex align-items-center">
            <i class="bi bi-card-text me-2 fs-4"></i>
            <h4 class="mb-0">Site ayarları Düzenle</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Phone" class="form-label fw-bold"></label>
                        <input asp-for="Phone" class="form-control" placeholder="Telefon giriniz" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="WhatsApp" class="form-label fw-bold"></label>
                        <input asp-for="WhatsApp" class="form-control" placeholder="Whatsapp numarası giriniz" />
                        <span asp-validation-for="WhatsApp" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label fw-bold"></label>
                        <input asp-for="Email" class="form-control" placeholder="E-posta giriniz" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Address" class="form-label fw-bold"></label>
                        <input asp-for="Address" class="form-control" placeholder="Adres giriniz" />
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Facebook" class="form-label fw-bold"></label>
                        <input asp-for="Facebook" class="form-control" placeholder="Facebook" />
                        <span asp-validation-for="Facebook" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Instagram" class="form-label fw-bold"></label>
                        <input asp-for="Instagram" class="form-control" placeholder="Instagram" />
                        <span asp-validation-for="Instagram" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Youtube" class="form-label fw-bold"></label>
                        <input asp-for="Youtube" class="form-control" placeholder="Youtube" />
                        <span asp-validation-for="Youtube" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Keywords" class="form-label fw-bold"></label>
                        <input asp-for="Keywords" class="form-control" placeholder="Meta-Keywords" />
                        <span asp-validation-for="Keywords" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="MetaDescription" class="form-label fw-bold"></label>
                        <input asp-for="MetaDescription" class="form-control" placeholder="Meta-Description" />
                        <span asp-validation-for="MetaDescription" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="MetaTitle" class="form-label fw-bold"></label>
                        <input asp-for="MetaTitle" class="form-control" placeholder="Meta-Title" />
                        <span asp-validation-for="MetaTitle" class="text-danger"></span>
                    </div>


                    <div class="col-12">
                        <label asp-for="Language" class="form-label fw-semibold"></label>
                        <select asp-for="Language" class="form-select"
                                asp-items="Html.GetEnumSelectList<Language>()">
                        </select>
                        <span asp-validation-for="Language" class="text-danger"></span>

                    </div>

                    <div class="col-12">
                        <input type="submit" value="Ekle" class="btn btn-primary btn-lg w-100 mt-3 shadow-sm" />
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
<style>
    .card-header {
        display: flex;
        align-items: center;
        font-size: 1.2rem;
    }

    input.form-control, textarea.form-control {
        border-radius: 8px;
        box-shadow: none;
    }

        input.form-control:focus, textarea.form-control:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 8px rgba(13, 110, 253, 0.2);
        }

</style>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const editor = new Jodit('#AboutEditor', {
                height: 400
            });
        });
    </script>
}
