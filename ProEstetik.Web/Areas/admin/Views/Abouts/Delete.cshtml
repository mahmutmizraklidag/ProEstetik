@model About

@{
    ViewData["Title"] = "Sil";
}




<div class="container my-4">
    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-header bg-danger text-white d-flex align-items-center">
            <i class="bi bi-exclamation-triangle-fill me-2 fs-4"></i>
            <h4 class="mb-0">Hakkımızda Sil</h4>
        </div>
        <div class="card-body">
            <div class="alert alert-warning mb-4">
                <i class="bi bi-info-circle-fill me-2"></i>
                Bu işlemi gerçekleştirdiğinizde hakkımızda <strong>kalıcı olarak silinecek!</strong>
            </div>

            <dl class="row">
                <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(model => model.Title)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Title)</dd>

                <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(model => model.Description)</dt>
                <dd class="col-sm-9">@Html.Raw(@Model.Description)</dd>

                <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(model => model.Keywords)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Keywords)</dd>

                <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(model => model.MetaDescription)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.MetaDescription)</dd>

                <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(model => model.MetaTitle)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.MetaTitle)</dd>

                <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(model => model.Language)</dt>
                <dd class="col-sm-9">@Html.Raw(@Model.Language)</dd>

            </dl>

            <form asp-action="Delete" class="d-flex justify-content-between mt-4">
                <input type="hidden" asp-for="Id" />
                <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                    <i class="bi bi-arrow-left"></i> Vazgeç
                </a>
                <button type="submit" class="btn btn-danger btn-lg shadow-sm">
                    <i class="bi bi-trash-fill"></i> SİL
                </button>
            </form>
        </div>
    </div>
</div>
<style>
    .card-header {
        display: flex;
        align-items: center;
        font-size: 1.2rem;
    }

    dl dt {
        color: #444;
    }

    .alert-warning {
        font-size: 1rem;
    }

</style>