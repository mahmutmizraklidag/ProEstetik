@model About

@{
    ViewData["Title"] = "Düzenle";
}




<div class="container my-4">
    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-header bg-warning text-dark d-flex align-items-center">
            <i class="bi bi-card-text me-2 fs-4"></i>
            <h4 class="mb-0">Hakkımızda Düzenle</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                <input type="hidden" asp-for="Id" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Title" class="form-label fw-bold"></label>
                        <input asp-for="Title" class="form-control" placeholder="Başlık" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Keywords" class="form-label fw-bold"></label>
                        <input asp-for="Keywords" class="form-control" />
                        <span asp-validation-for="Keywords" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="MetaDescription" class="form-label fw-bold"></label>
                        <input asp-for="MetaDescription" class="form-control" />
                        <span asp-validation-for="MetaDescription" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="MetaTitle" class="form-label fw-bold"></label>
                        <input asp-for="MetaTitle" class="form-control" />
                        <span asp-validation-for="MetaTitle" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Description" class="form-label fw-bold"></label>
                        <textarea id="AboutEditor" asp-for="Description" class="form-control"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Language" class="form-label fw-semibold"></label>
                        <select asp-for="Language" class="form-select"
                                asp-items="Html.GetEnumSelectList<Language>()">
                        </select>
                        <span asp-validation-for="Language" class="text-danger"></span>
                    </div>

                    <div class="col-12 d-flex justify-content-between align-items-center mt-3">
                        <a asp-area="Admin" asp-action="Index" class="btn btn-outline-secondary btn-lg">
                            <i class="bi bi-arrow-left"></i> Listeye Dön
                        </a>
                        <input type="submit" value="Kaydet" class="btn btn-warning btn-lg shadow-sm" />
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
<style>
    .card-header {
        display: flex;
        align-items: center;
        font-size: 1.2rem;
    }

    input.form-control, textarea.form-control {
        border-radius: 8px;
        box-shadow: none;
    }

        input.form-control:focus, textarea.form-control:focus {
            border-color: #ffc107;
            box-shadow: 0 0 8px rgba(255, 193, 7, 0.2);
        }

</style>
@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const editor = new Jodit('#AboutEditor', {
                height: 400
            });
        });
    </script>
}