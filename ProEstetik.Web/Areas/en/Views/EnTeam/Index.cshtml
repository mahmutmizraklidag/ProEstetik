@model IEnumerable<Team>
@{
    ViewData["Title"] = "Team | PROESTETİK";
    ViewData["MetaDescription"] = "Meet Out Team.";
    ViewData["MetaKeywords"] = "";

}
<!-- Main -->
<!-- Header Banner -->
<div class="banner-header section-padding valign bg-img" data-overlay-dark="4" data-background="@Url.Content("~/img/bg1.png")" style="background-image: url(&quot;/img/bg1.png&quot;);">
    <div class="container">
        <div class="row">
            <div class="col-md-12 text-left caption mt-90">
                <h5>İzmir Pro Aesthetic Dental Clinic</h5>
                <h1>Team</h1>
            </div>
        </div>
    </div>
</div>
<!-- News  -->
<section class="news section-padding bg-cream">
    <div class="container">
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-3 mb-30">
                    <div class="item">
                        <a asp-asp-area="en" asp-controller="EnTeam" asp-action="Detail" asp-route-slug="@item.Slug">
                            <div class="position-re o-hidden">
                                <img src="@Url.Content("~/image/" + item.Image)" alt="@item.Name">
                            </div>
                            <div class="con">
                                <h5>@item.Position @item.Name</h5>
                            </div>
                        </a>
                    </div>
                </div>
            }



        </div>

    </div>
</section>



