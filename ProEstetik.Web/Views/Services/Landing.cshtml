                <p>
                    Tedavi süreciniz hakkında detaylı bilgi almak ve size uygun planlamayı oluşturmak için bizimle iletişime geçebilirsiniz.
                </p>

                <div class="service-landing-cta-actions">
                    <div class="butn-light">
                        <a href="@whatsappUrl" target="_blank" rel="noopener">
                            <span>WhatsApp ile Yaz</span>
                        </a>
                    </div>

                    <div class="butn-dark">
                        <a href="tel:@phoneText.Replace(" ", "")">
                            <span>@phoneText</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
