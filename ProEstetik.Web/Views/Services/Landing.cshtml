@model ProEstetik.Web.Entities.Service
@using System.Text.RegularExpressions

@functions {
    private string StripHtml(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return string.Empty;

        var noHtml = Regex.Replace(value, "<.*?>", " ");
        return Regex.Replace(noHtml, @"\s+", " ").Trim();
    }

    private string Shorten(string? value, int maxLength)
    {
        var text = StripHtml(value);

        if (string.IsNullOrWhiteSpace(text))
            return string.Empty;

        if (text.Length <= maxLength)
            return text;

        return text.Substring(0, maxLength).Trim() + "...";
    }

    private bool IsHtml(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return false;

        return value.Contains("<") && value.Contains(">");
    }

    private string ResolveMedia(string? value, string fallback = "~/images/slider/1.jpg")
    {
        if (string.IsNullOrWhiteSpace(value))
            return Url.Content(fallback);

        value = value.Trim();

        if (value.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
            value.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
            return value;

        if (value.StartsWith("~/"))
            return Url.Content(value);

        return Url.Content("~/" + value.TrimStart('/'));
    }
}

@{
    var title = Model.Title;
    var leadText = !string.IsNullOrWhiteSpace(Model.ShortDescription)
        ? Model.ShortDescription
        : Shorten(Model.Description, 180);

    var metaDescription = !string.IsNullOrWhiteSpace(Model.MetaDescription)
        ? Model.MetaDescription
        : Shorten(Model.ShortDescription ?? Model.Description, 155);

    ViewData["Title"] = !string.IsNullOrWhiteSpace(Model.MetaTitle)
        ? Model.MetaTitle
        : $"{title} | Pro Estetik Diş Kliniği";

    ViewData["MetaDescription"] = metaDescription;
    ViewData["Keywords"] = Model.Keywords;

    var heroImage = ResolveMedia(Model.Image ?? Model.Image2);
    var secondImage = ResolveMedia(Model.Image2 ?? Model.Image);

    var whatsappNumber = "905327731035";
    var phoneText = "+90 232 463 4747";

    var whatsappMessage = Uri.EscapeDataString($"Merhabalar, {title} hakkında bilgi almak ve randevu oluşturmak istiyorum.");
    var whatsappUrl = $"https://wa.me/{whatsappNumber}?text={whatsappMessage}";
}

<!-- Hero -->
<section class="service-landing-hero bg-img bg-fixed" data-overlay-dark="5" style="background-image: url('@Url.Content("~/image/" + Model.Image)');">
    <div class="container">
        <div class="row align-items-center min-vh-90">
            <div class="col-lg-10 col-xl-9">
                <div class="service-landing-kicker">Pro Estetik Diş Kliniği</div>

                <h1>@title</h1>

                @if (!string.IsNullOrWhiteSpace(leadText))
                {
                    <p>@leadText</p>
                }

                <div class="service-landing-actions">
                    <div class="butn-light">
                        <a href="#randevu">
                            <span>Randevu Al</span>
                        </a>
                    </div>

                    <div class="butn-dark">
                        <a href="#detay">
                            <span>Detayları İncele</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <a href="#detay" class="service-landing-scroll" aria-label="Detaylara git">
        <i class="ti-angle-down"></i>
    </a>
</section>

<!-- Mini Navigation -->
<div class="service-landing-nav">
    <div class="container">
        <div class="service-landing-nav-inner">
            <a href="#detay">Genel Bakış</a>
            <a href="#avantajlar">Avantajlar</a>
            <a href="#surec">Süreç</a>
            <a href="#sss">Sık Sorulanlar</a>
            <a href="#randevu">Randevu</a>
        </div>
    </div>
</div>

<!-- Detail -->
