                    {
                        @Html.Raw(Model.Description)
                    }
                    else if (!string.IsNullOrWhiteSpace(Model.Description))
                    {
                        <p>@Model.Description</p>
                    }
                    else
                    {
                        <p>
                            Bu hizmet hakkında detaylı bilgi ve size uygun tedavi planı için Pro Estetik Diş Kliniği ile iletişime geçebilirsiniz.
                        </p>
                    }
                </div>

                <div class="service-landing-detail-buttons">
                    <div class="butn-dark">
                        <a href="#randevu">
                            <span>Randevu Oluştur</span>
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="service-landing-image-card">
                    <img src="@Url.Content("~/image/" + Model.Image)" alt="@title" loading="lazy">

                    <div class="service-landing-image-note">
