<section class="team section-padding bg-cream">
    <div class="container">
        <div class="row">
            <div class="col-md-12">
                <div class="section-subtitle">İzmir Pro Estetik Diş Kliniği</div>
                <div class="section-title">Blog</div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12 owl-carousel owl-theme">
                @foreach (var blog in DataRequestModel.Blogs)
                {
                    <div class="item">
                        <div class="img">
                            <a asp-controller="Blog" asp-action="Detail" asp-route-slug="@blog.Slug">
                                <img src="@Url.Content("~/image/" + blog.Image)" alt="@blog.Title">
                            </a>
                        </div>
                        <div class="info">
                            <h6>
                                <a asp-controller="Blog" asp-action="Detail" asp-route-slug="@blog.Slug">
                                    @blog.Title
                                </a>
                            </h6>
                        </div>
                    </div>
                }


            </div>
        </div>
    </div>
</section>